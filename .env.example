PAYMOB_API_KEY=pk_live_or_test_here
PAYMOB_INTEGRATION_ID=123456
PAYMOB_IFRAME_ID=123456
PAYMOB_BASE=https://accept.paymob.com

# سر تستخدمه لحماية webhook الخاص بـ QNB
QNB_WEBHOOK_SECRET=put_a_long_random_secret_here

# اختيار 1: اتركه فاضيًا لو ستستخدم ملف firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cashier system sync (external POS/DB API)
# Example: https://your-cashier-system.com/api/bookings/sync
CASHIER_SYNC_URL=
# Optional Bearer token used in Authorization header
CASHIER_SYNC_TOKEN=
# Timeout for cashier API request in milliseconds
CASHIER_SYNC_TIMEOUT_MS=12000
# "paid" = send only after successful payment, "all" = send all events
CASHIER_SYNC_ON=paid

# بعد الدفع (Paymob / 3DS) — ضروري لإرجاع العميل لصفحة الإيصال (بدونها غالبًا ترجع لصفحة الحجز من غير إيصال)
PUBLIC_SITE_URL=https://karawan-cinema.web.app

# أو رابط الإيصال كاملًا مع placeholder (يغني عن PUBLIC_SITE_URL):
# PAYMOB_RETURN_URL=https://karawan-cinema.web.app/payment-done.html?ref={{merchant_order_id}}

# لو لوحة Paymob تطلب حقل redirect_url إضافي، ضع 1
# PAYMOB_DUPLICATE_REDIRECT_FIELD=1
